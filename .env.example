# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for MongoDB Atlas. If omitted, Aivora will fall back to a local JSON sandbox.
# MONGODB_URI=''

# JWT_SECRET: Secret key for signing JWT authorization tokens.
# JWT_SECRET=''

# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET for Google Sign-In / Identity OAuth 2.0
# GOOGLE_CLIENT_ID=''
# GOOGLE_CLIENT_SECRET=''

# GOOGLE_REDIRECT_URI: exact callback URL registered in Google Cloud Console.
# MUST match: https://<your-vercel-domain>/api/auth/google/callback
# Set this on Vercel (and locally) so the OAuth consent screen and the
# server-side token exchange use the same redirect_uri. If omitted, the
# server derives it from the incoming request host.
# GOOGLE_REDIRECT_URI='https://your-app.vercel.app/api/auth/google/callback'

# NOTE: On Vercel these variables are NOT read from this file. Configure them
# in the Vercel dashboard: Project > Settings > Environment Variables
# (MONGODB_URI, JWT_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REDIRECT_URI).


